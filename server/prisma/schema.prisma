generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

generator clientServer {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model Order {
  id                  String   @id @default(uuid())
  orderId             String   @unique @map("order_id")
  customerName        String   @map("customer_name")
  phoneNumber         String   @map("phone_number")
  email               String?
  service             String
  category            String?
  location            String?
  deliveryMethod      String   @map("delivery_method")
  deliveryDetails     String?  @map("delivery_details")
  pickupState         String?  @map("pickup_state")
  pickupCity          String?  @map("pickup_city")
  pickupLocation      String?  @map("pickup_location")
  deadline            String?
  amount              Decimal  @default(0) @db.Decimal(12, 2)
  status              String   @default("Pending")
  printColor          String?  @map("print_color")
  paperType           String?  @map("paper_type")
  pages               Int?
  copies              Int      @default(1)
  expressService      Boolean  @default(false) @map("express_service")
  printLayout         String?  @map("print_layout")
  finishingOption     String?  @map("finishing_option")
  specificInstruction String?  @map("specific_instruction")
  paystackRef         String?  @map("paystack_ref")
  fileUrl             String?  @map("file_url")
  documentText        String?  @map("document_text")
  hardcopyPickupDate  String?  @map("hardcopy_pickup_date")
  hardcopyPickupTime  String?  @map("hardcopy_pickup_time")
  hardcopyState       String?  @map("hardcopy_state")
  hardcopyCity        String?  @map("hardcopy_city")
  hardcopyContactName String?  @map("hardcopy_contact_name")
  hardcopyContactPhone String? @map("hardcopy_contact_phone")
  hardcopyDocCount    Int?     @map("hardcopy_doc_count")
  hardcopyInstructions String? @map("hardcopy_instructions")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("orders")
}

model PartnerApplication {
  id          String   @id @default(uuid())
  fullName    String   @map("full_name")
  companyName String   @map("company_name")
  email       String
  address     String
  services    String?
  status      String   @default("Pending")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("partner_applications")
}

model OtpCode {
  id         String   @id @default(uuid())
  identifier String
  code       String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([identifier])
  @@map("otp_codes")
}
